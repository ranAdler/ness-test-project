# Browser Configuration
BROWSER=chromium
HEADLESS=true
SLOW_MO=0

# Base URLs
BASE_URL=http://www.ebay.com
DEMO_URL=http://example-ebay.com

# Test Data
DEFAULT_TIMEOUT=30000
IMPLICIT_WAIT=10000
EXPLICIT_WAIT=20000

# Logging
LOG_LEVEL=INFO
SCREENSHOT_ON_FAILURE=true

# Report Configuration
REPORT_TYPE=allure
REPORT_DIR=allure-results