# Development Environment
BROWSER=chromium
HEADLESS=false
SLOW_MO=500

BASE_URL=https://ebay.com
DEMO_URL=https://ebay.com

DEFAULT_TIMEOUT=30000
IMPLICIT_WAIT=10000
EXPLICIT_WAIT=20000

LOG_LEVEL=DEBUG
SCREENSHOT_ON_FAILURE=true

REPORT_TYPE=allure
REPORT_DIR=allure-results

# Login Test Credentials
# Valid credentials for successful login test
EBAY_USERNAME=valid_user@example.com
EBAY_PASSWORD=ValidPassword123

# Invalid username for wrong username test
INVALID_USERNAME=invalid_user_does_not_exist@example.com

# Invalid password for wrong password test
INVALID_PASSWORD=WrongPassword123